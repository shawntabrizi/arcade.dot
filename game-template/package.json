{
  "name": "leaderboard-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:boot": "npm run build && playwright test --config playwright.boot.config.ts",
    "smoke:read": "node scripts/smoke-read.mjs",
    "arcade:gen-thumbnail": "node scripts/gen-thumbnail.mjs",
    "arcade:deploy-contract": "node scripts/deploy-contract.mjs",
    "arcade:upload-thumbnail": "node scripts/upload-thumbnail.mjs",
    "arcade:register": "node scripts/register-listing.mjs",
    "arcade:verify": "node scripts/verify-listing.mjs",
    "arcade:ship": "node scripts/ship.mjs"
  },
  "dependencies": {
    "@novasamatech/host-api": "^0.8.4",
    "@novasamatech/host-api-wrapper": "^0.8.4",
    "@parity/product-sdk-address": "^0.1.1",
    "@parity/product-sdk-tx": "^0.2.9",
    "@polkadot-api/sdk-ink": "^0.7.0",
    "@polkadot-api/ws-provider": "^0.9.0",
    "polkadot-api": "^2.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@polkadot-labs/hdkd": "^0.0.28",
    "@polkadot-labs/hdkd-helpers": "^0.0.30",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "bulletin-deploy": "^0.8.3",
    "multiformats": "^14.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^3.2.4"
  }
